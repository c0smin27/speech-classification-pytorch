{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNmI96aS/QzxqnZTNbIBrqh"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["# Speech Classification from Scratch"],"metadata":{"id":"OZjYMrkQt1vN"}},{"cell_type":"markdown","source":["### X-vector Implementation Following [SpeechBrain Tutorial](https://speechbrain.readthedocs.io/en/latest/tutorials/tasks/speech-classification-from-scratch.html)"],"metadata":{"id":"JoEV6pcPt4aq"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"CPBNvJr-r1Q0","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768603374912,"user_tz":-120,"elapsed":13,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"cd77cc01-6a19-48b5-fbb9-24a0521c5113"},"outputs":[{"output_type":"stream","name":"stdout","text":["Director curent: D:\\Projects\\ColabLocal\\ASRSV\\speech_classification\n"]}],"source":["# ------------------------------\n","# Setup Initial (Rulare Locala)\n","# ------------------------------\n","\n","import os\n","\n","base_path = r\"D:\\Projects\\ColabLocal\\ASRSV\\speech_classification\"\n","os.makedirs(base_path, exist_ok=True)\n","\n","os.chdir(base_path)\n","print(f\"Director curent: {os.getcwd()}\")"]},{"cell_type":"code","source":["# ------------------------------\n","# Instalare SpeechBrain\n","# ------------------------------\n","\n","import speechbrain as sb\n","import torch\n","\n","print(f\"SpeechBrain version: {sb.__version__}\")\n","print(f\"PyTorch version: {torch.__version__}\")\n","print(f\"CUDA available: {torch.cuda.is_available()}\")\n","if torch.cuda.is_available():\n","    print(f\"=\"*40)\n","    print(f\"CUDA version: {torch.version.cuda}\")\n","    print(f\"GPU: {torch.cuda.get_device_name(0)}\")"],"metadata":{"id":"m5sOHNDwsPJV","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":