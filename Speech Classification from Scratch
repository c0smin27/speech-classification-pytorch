_targets == speaker_id).astype(int)\n","\n","    # Recalculam confidence pentru speaker specific\n","    # Folosim predictiile si confidence-ul existent\n","    y_scores = np.zeros(len(all_predictions))\n","    for i in range(len(all_predictions)):\n","        if all_predictions[i] == speaker_id:\n","            y_scores[i] = all_confidences[i]\n","        else:\n","            # Pentru clasa negativa, inversam confidence-ul\n","            y_scores[i] = 1 - all_confidences[i] if all_predictions[i] != speaker_id else 0\n","\n","    # Verificare: trebuie sa avem samples pozitive\n","    if np.sum(y_true_binary) == 0:\n","        continue\n","\n","    # Calcul ROC curve\n","    fpr, tpr, thresholds = roc_curve(y_true_binary, y_scores)\n","\n","    # Calcul FNR (False Negative Rate)\n","    fnr = 1 - tpr\n","\n","    # Gasim EER: punctul unde FPR = FNR\n","    # Folosim interpolare pentru a gasi intersectia exacta\n","    try:\n","        eer = brentq(lambda x: 1. - x - interp1d(fpr, tpr)(x), 0., 1.)\n","        eer_list.append(eer)\n","        speakers_with_eer.append(speaker_id)\n","    except:\n","        # Daca nu putem calcula EER pentru acest speaker\n","        continue\n","\n","# Calcul EER mediu (Macro-averaged)\n","if len(eer_list) > 0:\n","    macro_eer = np.mean(eer_list)\n","    std_eer = np.std(eer_list)\n","\n","    # Gaseste toti speakerii cu EER = 0\n","    perfect_speakers = [speakers_with_eer[i] for i, eer in enumerate(eer_list) if eer == 0]\n","\n","    print(f\"EER Statistics:\")\n","    print(f\"Macro-averaged EER: {macro_eer:.2%}\")\n","    print(f\"Std Dev: {std_eer:.4f}\")\n","    print(f\"Min EER: 0.00% ({len(perfect_speakers)} speakers)\")\n","    print(f\"Max EER: {max(eer_list):.2%} (Speaker {speakers_with_eer[np.argmax(eer_list)]})\")\n","    print(f\"Speakers evaluated: {len(eer_list)}/28\")\n","    print(\"=\"*60)\n","\n","    # Vizualizare distributie EER\n","    plt.figure(figsize=(10, 5))\n","    plt.hist(eer_list, bins=15, color='ste