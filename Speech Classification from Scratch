                                      \n"]},{"output_type":"stream","name":"stdout","text":["Dataset descarcat si dezarhivat!\n"]}]},{"cell_type":"code","source":["# ------------------------------\n","# Creare Manifest JSON\n","# ------------------------------\n","\n","import os\n","import glob\n","import random\n","import json\n","import soundfile as sf\n","from collections import defaultdict\n","\n","random.seed(42)\n","\n","# Folosim doar train-clean-5\n","train_folder = \"./data/LibriSpeech/train-clean-5\"\n","\n","# Cautare recursiva fisiere .flac\n","all_wav_list = glob.glob(os.path.join(train_folder, \"**/*.flac\"), recursive=True)\n","print(f\"Total fisiere gasite: {len(all_wav_list)}\")\n","\n","def extract_speaker_id(wav_path):\n","    return os.path.basename(os.path.dirname(os.path.dirname(wav_path)))\n","\n","# Grupeaza fisierele pe vorbitori\n","speaker_to_wavs = defaultdict(list)\n","for wav in all_wav_list:\n","    spk_tag = extract_speaker_id(wav)\n","    speaker_to_wavs[spk_tag].append(wav)\n","\n","speakers = sorted(list(speaker_to_wavs.keys()))\n","print(f\"Numar vorbitori: {len(speakers)}\")\n","\n","# Split 70/15/15 pentru fiecare vorbitor\n","train_wav_list = []\n","valid_wav_list = []\n","test_wav_list = []\n","\n","for spk, wavs in speaker_to_wavs.items():\n","  random.shuffle(wavs)\n","  n_total = len(wavs)\n","\n","  # Calcul proportii\n","  n_train = int(0.70 * n_total)\n","  n_valid = int(0.15 * n_total)\n","\n","  # Asigura minim 1 fisier in fiecare set pentru fiecare vorbitor\n","  if n_train == 0:\n","    n_train = 1\n","  if n_valid == 0:\n","    n_valid = 1\n","  if n_train + n_valid >= n_total:\n","    # Daca nu sunt suficiente fisiere, ajusteaza\n","    n_train = max(1, n_total - 2)\n","    n_valid = 1\n","\n","  train_wav_list.extend(wavs[:n_train])\n","  valid_wav_list.extend(wavs[n_train:n_train+n_valid])\n","  test_wav_list.extend(wavs[n_train+n_valid:])\n","\n","print(f\"Train: {len(train_wav_list)} fisiere\")\n","print(f\"Valid: {len(valid_wav_list)} fisiere\")\n","print(f\"Test: {len(test_wav_list)} fisiere\")\n","\n","# Mapping unic pentru toti vorbitorii\n","spk_to_id = {spk: i for i, spk in enumerate(speakers)}\n","print(f\"Numar clase: {len(speakers)}\")\n","\n","# Functie pentru creare JSON cu info durata audio\n","def create_json(wav_list, json_file):\n","    json_dict = {}\n","    for idx, wav_file in enumerate(wav_list):\n","        # Citeste doar metadata cu soundfile.info()\n","        info = sf.info(wav_file)\n","        duration = info.duration\n","\n","        # ID unic\n","        uttid = os.path.splitext(os.path.basename(wav_file))[0]\n","\n","        # ID vorbitor\n","        spk_tag = extract_speaker_id(wav_file)\n","        spk_id = spk_to_id[spk_tag]\n","\n","        # Construire dictionar\n","        json_dict[uttid] = {\n","            \"wav\": wav_file,\n","            \"length\": duration,\n","            \"spk_id\": spk_id,\n","            \"spk_tag\": spk_tag\n","        }\n","\n","        # Afisare progres la fiecare 100 de fisiere\n","        if (idx + 1) % 100 == 0:\n","            print(f\"  {idx + 1}/{len(wav_list)} fisiere procesate...\")\n","\n","    # Salvare JSON\n","    with open(json_file, \"w\") as f:\n","        json.dump(json_dict, f, indent=2)\n","    print(f\"{json_file} creat: {len(json_dict)} inregistrari\")\n","\n","# Generare JSON-uri\n","print(\"\\nCreare train.json...\")\n","create_json(train_wav_list, \"train.json\")\n","print(\"\\nCreare valid.json...\")\n","create_json(valid_wav_list, \"valid.json\")\n","print(\"\\nCreare test.json...\")\n","create_json(test_wav_list, \"test.json\")\n","print(\"\\nProces finalizat!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bLU2bAJnsal8","executionInfo":{"status":"ok","timestamp":1768601270472,"user_tz":-120,"elapsed":11383,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"a2271ad1-4621-43ee-992e-551bac2703f6"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Total fisiere gasite: 1519\n","Numar vorbitori: 28\n","Train: 1050 fisiere\n","Valid: 215 fisiere\n","Test: 254 fisiere\n","Numar clase: 28\n","\n","Creare train.json...\n","  100/1050 fisiere procesate...\n","  200/1050 fisiere procesate...\n","  300/1050 fisiere procesate...\n","  400/1050 fisiere procesate...\n","  500/1050 fisiere procesate...\n","  600/1050 fisiere procesate...\n","  700/1050 fisiere procesate...\n","  800/1050 fisiere procesate...\n","  900/1050 fisiere procesate...\n","  1000/1050 fisiere procesate...\n","train.json creat: 1050 inregistrari\n","\n","Creare valid.json...\n","  100/215 fisiere procesate...\n","  200/215 fisiere procesate...\n","valid.json creat: 215 inregistrari\n","\n","Creare test.json...\n","  100/254 fisiere procesate...\n","  200/254 fisiere procesate...\n","test.json creat: 254 inregistrari\n","\n","Proces finalizat!\n"]}]},{"cell_type":"code","source":["# ------------------------------\n","# Verificare consistenta speaker IDs\n","# ------------------------------\n","\n","import json\n","\n","with open(\"train.json\", \"r\") as f:\n","  train_data = json.load(f)\n","with open(\"valid.json\", \"r\") as f:\n","  valid_data = json.load(f)\n","with open(\"test.json\", \"r\") as f:\n","  test_data = json.load(f)\n","\n","train_spks = set([v[\"spk_id\"] for v in train_data.values()])\n","valid_spks = set([v[\"spk_id\"] for v in valid_data.values()])\n","test_spks = set([v[\"spk_id\"] for v in test_data.values()])\n","\n","print(f\"Train speakers: {len(train_spks)} - {len(train_data)} fisiere\")\n","print(f\"Valid speakers: {len(valid_spks)} - {len(valid_data)} fisiere\")\n","print(f\"Test speakers: {len(test_spks)} - {len(test_data)} fisiere\")\n","print(f\"Overlap train/valid/test: {len(train_spks.intersection(valid_spks).intersection(test_spks))} vorbitori comuni\")\n","\n","# Verifica speaker IDs\n","print(f\"\\nPrimii 5 train speakers: {sorted(list(train_spks))[:5]}\")\n","print(f\"Primii 5 valid speakers: {sorted(list(valid_spks))[:5]}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2tONRFI568vM","executionInfo":{"status":"ok","timestamp":1768601568765,"user_tz":-120,"elapsed":10,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"d40532b6-0393-4fc9-a3ce-673b0a447678"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Train speakers: 28 - 1050 fisiere\n","Valid speakers: 28 - 215 fisiere\n","Test speakers: 28 - 254 fisiere\n","Overlap train/valid/test: 28 vorbitori comuni\n","\n","Primii 5 train speakers: [0, 1, 2, 3, 4]\n","Primii 5 valid speakers: [0, 1, 2, 3, 4]\n"]}]},{"cell_type":"code","source":["# ------------------------------\n","# Definire Dataset\n","# ------------------------------\n","\n","import speechbrain as sb\n","# DynamicItemDataset - lazy loading\n","from speechbrain.dataio.dataset import DynamicItemDataset\n","\n","# Pipeline audio: citire fisier de pe disc\n","@sb.utils.data_pipeline.takes(\"wav\")\n","@sb.utils.data_pipeline.provides(\"sig\")\n","def audio_pipeline(wav):\n","    sig = sb.dataio.dataio.read_audio(wav)\n","    return sig\n","\n","# Pipeline label: returneaza ID numeric\n","@sb.utils.data_pipeline.takes(\"spk_id\")\n","@sb.utils.data_pipeline.provides(\"spk_id_encoded\")\n","def label_pipeline(spk_id):\n","    # Returneaza ID-ul asa cum este (deja numeric)\n","    return spk_id\n","\n","# Creare dataset-uri\n","train_set = DynamicItemDataset.from_json(\n","    json_path=\"train.json\",\n","    dynamic_items=[audio_pipeline, label_pipeline],\n","    # id = id unic dataset; sig = semnal; spk_id = ID vorbitor\n","    output_keys=[\"id\", \"sig\", \"spk_id_encoded\"]\n",")\n","valid_set = DynamicItemDataset.from_json(\n","    json_path=\"valid.json\",\n","    dynamic_items=[audio_pipeline, label_pipeline],\n","    output_keys=[\"id\", \"sig\", \"spk_id_encoded\"]\n",")\n","test_set = DynamicItemDataset.from_json(\n","    json_path=\"test.json\",\n","    dynamic_items=[audio_pipeline, label_pipeline],\n","    output_keys=[\"id\", \"sig\", \"spk_id_encoded\"]\n",")\n","\n","# Verificare\n","print(f\"Dataset-uri create:\")\n","print(f\"Train: {len(train_set)} sample-uri\")\n","print(f\"Valid: {len(valid_set)} sample-uri\")\n","print(f\"Test: {len(test_set)} sample-uri\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"87WCS_8EvHCk","executionInfo":{"status":"ok","timestamp":1768603385224,"user_tz":-120,"elapsed":21,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"9c9eede9-071e-4816-ce42-6db392932a85"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dataset-uri create:\n","Train: 1050 sample-uri\n","Valid: 215 sample-uri\n","Test: 254 sample-uri\n"]}]},{"cell_type":"code","source":["# ------------------------------\n","# Redare Audio Exemplu\n","# ------------------------------\n","\n","import IPython.display as ipd\n","import matplotlib.pyplot as plt\n","import numpy as np\n","\n","# Selectare fisier random\n","exemplu = train_set[0]\n","audio_signal = exemplu['sig'].numpy()\n","speaker_id = exemplu['spk_id_encoded']\n","\n","print(f\"ID fisier: {exemplu['id']}\")\n","print(f\"Speaker ID: {speaker_id}\")\n","print(f\"Durata: {len(audio_signal)/16000:.2f} secunde\")\n","print(f\"Sample rate: 16000 Hz\")\n","\n","# Afisare forma de unda\n","plt.figure(figsize=(12, 3))\n","plt.plot(audio_signal)\n","plt.title(f\"Forma de unda - Speaker {speaker_id}\")\n","plt.xlabel(\"Sample\")\n","plt.ylabel(\"Amplitudine\")\n","plt.tight_layout()\n","plt.show()\n","\n","# Redare audio\n","print(\"Redare audio:\")\n","ipd.display(ipd.Audio(audio_signal, rate=16000))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":452},"id":"UmotY_T5g1q7","executionInfo":{"status":"ok","timestamp":1768603387705,"user_tz":-120,"elapsed":564,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"8e6fe4a9-5fe9-4d6b-d431-af4254b5fcfc"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["ID fisier: 1088-134315-0057\n","Speaker ID: 0\n","Durata: 13.53 secunde\n","Sample rate: 16000 Hz\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x300 with 1 Axes>"],"image/png":""},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Redare audio:\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.lib.display.Audio object>"],"text/html":["\n","                <audio  controls=\"controls\" >\n","                    <source src=\"data:audio/wav;base64,\" type=\"audio/wav\" />\n","                    Your browser does not support the audio element.\n","                </audio>\n","              "]},"metadata":{}}]},{"cell_type":"code","source":["# ------------------------------\n","# Definire Model\n","# ------------------------------\n","\n","import speechbrain as sb\n","import torch\n","import torch.nn.functional as F\n","import os\n","\n","# Functie masurare acuratete\n","def compute_accuracy(predictions, targets):\n","    \"\"\"Calculeaza acuratetea: compara predictiile cu targeturile\"\"\"\n","    predicted_labels = predictions.argmax(dim=1)\n","    correct = (predicted_labels == targets).float()\n","    return correct\n","\n","# Clasa principala pentru antrenare\n","class SimpleBrain(sb.Brain):\n","\n","  def __init__(self, *args, **kwargs):\n","        super().__init__(*args, **kwargs)\n","        # Liste pentru learning curves\n","        self.train_loss_history = []\n","        self.valid_loss_history = []\n","        self.valid_acc_history = []\n","        self.best_valid_acc = 0.0 # Tracking accuracy\n","\n","  def compute_forward(self, batch, stage):\n","        \"\"\"Forward pass: semnal audio -> trasaturi -> model -> predictii\"\"\"\n","        batch = batch.to(self.device)\n","        wavs, wav_lens = batch.sig\n","\n","        # Extragere trasaturi Fbank (Log-Mel Filterbank)\n","        # Reorezentare frecventa-timp pentru audio\n","        feats = self.modules.compute_features(wavs)\n","        # Normalizare pt training stabil\n","        feats = self.modules.mean_var_norm(feats, wav_lens)\n","\n","        # Model Xvector: return [batch, time, features]\n","        xvector_out = self.modules.xvector(feats)\n","\n","        # Aplicare pooling (mean + std) pentru a obtine [batch, features]\n","        pooled = self.modules.pooling(xvector_out, wav_lens)\n","        embeddings = pooled.squeeze(1) # [batch, 1, features] -> [batch, features]\n","\n","        # Clasificare: [batch, features] -> [batch, n_classes]\n","        # Layer liniar care mapeaza embeddings la clase (28 speakeri)\n","        outputs = self.modules.classifier(embeddings)\n","\n","        # Log-softmax\n","        log_probs = F.log_softmax(outputs, dim=1)\n","        return log_probs\n","\n","  def compute_objectives(self, predictions, batch, stage):\n","        \"\"\"Calcul pierdere (Loss) si metrici\"\"\"\n","        # Acces direct la tensor pentru labels scalare\n","        spk_id = batch.spk_id_encoded # Tensor\n","\n","        # Asigura formatul corect: 1D tensor cu dtype long\n","        if len(spk_id.shape) > 1:\n","            spk_id = spk_id.squeeze()\n","        spk_id = spk_id.long() # Convert la long pentru nll_loss\n","\n","        # Calcul Loss cu PyTorch\n","        loss = F.nll_loss(predictions, spk_id)\n","\n","        # Masoara acuratetea si stocheaza predictii pentru valid/test\n","        if stage != sb.Stage.TRAIN:\n","            self.error_metrics.append(batch.id, predictions, spk_id)\n","            # Stocheaza predictii si targets pentru metrici detaliate\n","            predicted_labels = predictions.argmax(dim=1)\n","            self.all_predictions.extend(predicted_labels.cpu().numpy().tolist())\n","            self.all_targets.extend(spk_id.cpu().numpy().tolist())\n","\n","        return loss\n","\n","  def on_stage_start(self, stage, epoch):\n","        \"\"\"Initializare metrici la inceputul fiecarei etape\"\"\"\n","        if stage != sb.Stage.TRAIN:\n","            # Initializare cu functia de acuratete\n","            self.error_metrics = sb.utils.metric_stats.MetricStats(\n","                metric=compute_accuracy\n","            )\n","            # Liste pentru predictii si targets\n","            self.all_predictions = []\n","            self.all_targets = []\n","\n","  def on_stage_end(self, stage, stage_loss, epoch):\n","      \"\"\"Afisare rezultate si salvare checkpoint la sfarsitul etapei\"\"\"\n","      if stage == sb.Stage.TRAIN:\n","          self.train_loss = stage_loss\n","          self.train_loss_history.append(stage_loss)\n","      else:\n","          # Calcul acuratete\n","          stats = self.error_metrics.summarize()\n","          accuracy = stats['average']\n","\n","          # Salvare istoric\n","          self.valid_loss_history.append(stage_loss)\n","          self.valid_acc_history.append(accuracy)\n","\n","          print(f\"Epoca {epoch}: Train Loss={self.train_loss:.3f} | \"\n","                f\"Valid Loss={stage_loss:.3f} | Acuratete={accuracy:.2%}\")\n","\n","          # 1. SALVARE BEST ACCURACY (separat)\n","          if accuracy > self.best_valid_acc:\n","              self.best_valid_acc = accuracy\n","              best_acc_path = \"./checkpoints/best_acc_model.pt\"\n","              torch.save({\n","                  'epoch': epoch,\n","                  'modules': self.modules.state_dict(),\n","                  'accuracy': accuracy,\n","                  'valid_loss': stage_loss\n","              }, best_acc_path)\n","              print(f\">> NEW BEST ACC: {accuracy:.2%} salvat in {best_acc_path}\")\n","\n","          # 2. EARLY STOPPING pe LOSS\n","          if not hasattr(self, 'best_valid_loss'):\n","              self.best_valid_loss = stage_loss\n","              self.best_epoch = epoch\n","              self.patience_counter = 0\n","\n","          if stage_loss < self.best_valid_loss:\n","              self.best_valid_loss = stage_loss\n","              self.best_epoch = epoch\n","              self.patience_counter = 0\n","              print(f\">> NEW BEST LOSS: {stage_loss:.3f}\")\n","          else:\n","              self.patience_counter += 1\n","              print(f\">> Patience: {self.patience_counter}/5\")\n","\n","          # 3. SALVARE CHECKPOINT NORMAL\n","          os.makedirs(\"./checkpoints\", exist_ok=True)\n","          checkpoint_path = f\"./checkpoints/checkpoint_epoch_{epoch}.pt\"\n","          torch.save({\n","              'epoch': epoch,\n","              'modules': self.modules.state_dict(),\n","              'optimizer': self.optimizer.state_dict() if hasattr(self, 'optimizer') else None,\n","              'train_loss': self.train_loss,\n","              'valid_loss': stage_loss,\n","              'accuracy': accuracy,\n","              'best_epoch': self.best_epoch\n","          }, checkpoint_path)\n","          print(f\">> Checkpoint salvat: {checkpoint_path}\")\n","\n","          # 4. OPRIRE FORTATA (O SINGURA VERIFICARE)\n","          if self.patience_counter >= 5:\n","              print(f\"\\n>> EARLY STOPPING la epoca {epoch}\")\n","              print(f\">> Best Loss: epoca {self.best_epoch} ({self.best_valid_loss:.3f})\")\n","              print(f\">> Best Acc: {self.best_valid_acc:.2%}\")\n","              raise StopIteration\n","\n","print(\"Clasa SimpleBrain definita!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"d_PH_l3avJX3","executionInfo":{"status":"ok","timestamp":1768603388701,"user_tz":-120,"elapsed":15,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"bd0dddea-f4d9-48db-be53-12ed1d69657f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Clasa SimpleBrain definita!\n"]}]},{"cell_type":"code","source":["# ------------------------------\n","# Module si Hiperparametri\n","# ------------------------------\n","\n","import torch\n","from speechbrain.lobes.features import Fbank\n","from speechbrain.processing.features import InputNormalization\n","from speechbrain.nnet.CNN import Conv1d\n","from speechbrain.nnet.normalization import BatchNorm1d\n","from speechbrain.nnet.pooling import StatisticsPooling\n","import speechbrain as sb\n","import json\n","\n","# Citeste numarul de clase direct din JSON\n","with open(\"train.json\", \"r\") as f:\n","    train_data = json.load(f)\n","\n","# Extrage toate speaker IDs unice\n","all_spk_ids = set([v[\"spk_id\"] for v in train_data.values()])\n","n_classes = len(all_spk_ids)\n","print(f\"Numar de vorbitori (clase): {n_classes}\")\n","\n","# Definire module retea neurala\n","modules = torch.nn.ModuleDict({\n","    # Extragere trasaturi: transforma unda sonora in spectrograma\n","    \"compute_features\": Fbank(n_mels=40),\n","\n","    # Normalizare pe nivel de propozitie\n","    \"mean_var_norm\": InputNormalization(norm_type=\"sentence\", std_norm=False),\n","\n","    # TDNN simplificat (5 layere convolutionale)\n","    # Convolutii 1D care privesc context temporal -> Vede 5 frame-uri consecutiv\n","    # 'dilation=2' inseamna ca sare un frame\n","    \"xvector\": torch.nn.Sequential(\n","        # Layer 1-3: Extrag patterns locale (foneme, tranzitii vocale)\n","        Conv1d(input_shape=(None, None, 40), out_channels=512, kernel_size=5, dilation=1),\n","        BatchNorm1d(input_shape=(None, None, 512)),\n","        torch.nn.LeakyReLU(),\n","        Conv1d(input_shape=(None, None, 512), out_channels=512, kernel_size=3, dilation=2),\n","        BatchNorm1d(input_shape=(None, None, 512)),\n","        torch.nn.LeakyReLU(),\n","        Conv1d(input_shape=(None, None, 512), out_channels=512, kernel_size=3, dilation=3),\n","        BatchNorm1d(input_shape=(None, None, 512)),\n","        torch.nn.LeakyReLU(),\n","        # Layer 4-5: convolutii \"pointwise\" care combina features de la layerele anterioare,\n","        # fara a adauga context temporal\n","        Conv1d(input_shape=(None, None, 512), out_channels=512, kernel_size=1, dilation=1),\n","        BatchNorm1d(input_shape=(None, None, 512)),\n","        torch.nn.LeakyReLU(),\n","        Conv1d(input_shape=(None, None, 512), out_channels=1500, kernel_size=1, dilation=1),\n","        BatchNorm1d(input_shape=(None, None, 1500)),\n","        torch.nn.LeakyReLU(),\n","    ),\n","\n","    # Pooling: [batch, time, 1500] -> [batch, 1, 3000] (mean + std)\n","    \"pooling\": StatisticsPooling(),\n","\n","    # Clasificator: [batch, 3000] -> [batch, n_classes]\n","    # Inmulteste embedding-ul cu o matrice de ponderi (3000 x 28)\n","    # pentru a produce un scor pentru fiecare speaker\n","    \"classifier\": sb.nnet.linear.Linear(input_size=3000, n_neurons=n_classes)\n","})\n","\n","# Hiperparametri\n","hparams = {\n","    \"lr\": 0.001, # Learning rate standard pentru Adam optimizer\n","    \"epoch_counter\": sb.utils.epoch_loop.EpochCounter(limit=50),\n","    \"dataloader_options\": {\n","        \"batch_size\": 8,\n","        \"shuffle\": True,\n","        \"num_workers\": 0\n","    }\n","}\n","\n","print(\"Configuratie completa!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Pou_2eg-vI33","executionInfo":{"status":"ok","timestamp":1768603391222,"user_tz":-120,"elapsed":251,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"outputId":"cc1352f5-c94c-405f-beca-4e6dab7533cc"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["D:\\Projects\\ColabLocal\\venv\\Lib\\site-packages\\speechbrain\\utils\\autocast.py:188: FutureWarning: `torch.cuda.amp.custom_fwd(args...)` is deprecated. Please use `torch.amp.custom_fwd(args..., device_type='cuda')` instead.\n","  wrapped_fwd = torch.cuda.amp.custom_fwd(fwd, cast_inputs=cast_inputs)\n","C:\\Users\\Cosmin\\AppData\\Local\\Programs\\Python\\Python311\\Lib\\inspect.py:988: UserWarning: Module