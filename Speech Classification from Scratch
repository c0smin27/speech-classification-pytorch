"source":["# ------------------------------\n","# Confusion Matrix pe Test Set\n","# ------------------------------\n","\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from sklearn.metrics import confusion_matrix\n","import os\n","\n","output_dir = './test_dataset_results/'\n","os.makedirs(output_dir, exist_ok=True)\n","\n","# Generare confusion matrix\n","cm = confusion_matrix(all_targets, all_predictions)\n","\n","# Vizualizare\n","plt.figure(figsize=(14, 12))\n","sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', cbar=True,\n","            xticklabels=range(28), yticklabels=range(28),\n","            linewidths=0.5, linecolor='gray')\n","plt.title('Confusion Matrix - Test Set', fontsize=16, fontweight='bold', pad=20)\n","plt.xlabel('Speaker Prezis', fontsize=13)\n","plt.ylabel('Speaker Real', fontsize=13)\n","plt.tight_layout()\n","plt.savefig(os.path.join(output_dir, 'confusion_matrix_test.png'), dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","# Identificare erori specifice\n","print(\"=\"*70)\n","print(\"ANALIZA ERORILOR (Confuzii intre vorbitori)\")\n","print(\"=\"*70)\n","\n","erori_count = 0\n","for true_spk in range(28):\n","    for pred_spk in range(28):\n","        if true_spk != pred_spk and cm[true_spk, pred_spk] > 0:\n","            erori_count += cm[true_spk, pred_spk]\n","            print(f\"Speaker {true_spk} confundat cu Speaker {pred_spk}: {cm[true_spk, pred_spk]} erori\")\n","print(\"-\"*70)\n","print(f\"Total erori: {erori_count}/254\")\n","print(\"=\"*70)\n","\n","# Salvare confusion matrix\n","output_path_npy = os.path.join(output_dir, 'confusion_matrix_test.npy')\n","np.save(output_path_npy, cm)\n","print(f\"\\nConfusion matrix salvata in {output_path_npy}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"PT5hagLglqF5","executionInfo":{"status":"ok","timestamp":1768601813438,"user_tz":-120,"elapsed":2267,"user":{"displayName":"Cosmin Melinte","userId":"13361018463282633309"}},"output